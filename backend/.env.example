# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=<generate-with: openssl rand -hex 64>
MASTER_ADMIN_JWT_SECRET=<generate-with: openssl rand -hex 64>

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_LOCK_MINUTES=30

# ── Twilio (SMS reminders) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC<your-sid>
TWILIO_AUTH_TOKEN=<your-auth-token>
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
AUTO_REMINDERS_ENABLED=false
AUTO_REMINDERS_INTERVAL_MINUTES=60
AUTO_REMINDERS_LOOKBACK_DAYS=60
AUTO_REMINDERS_THROTTLE_DAYS=2

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-key>
EMAIL_FROM=noreply@yourdomain.com

# ── GST Verification ─────────────────────────────────────────────────────────
GSTIN_API_KEY=<your-gstin-api-key>

# ── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Google Maps (server-side geocoding + Places) ──────────────────────────────
# Restrict this key to: Maps JavaScript API, Places API (New), Geocoding API
# Add HTTP referrer restrictions in Google Cloud Console
GOOGLE_MAPS_API_KEY=<your-server-side-maps-key>

# ── Subscription JWT (optional RS256 signing) ─────────────────────────────────
SUBSCRIPTION_JWT_PRIVATE_KEY=<your-rsa-private-key-pem>
SUBSCRIPTION_JWT_PUBLIC_KEY=<your-rsa-public-key-pem>
SUBSCRIPTION_MAX_OFFLINE_SECONDS=604800
